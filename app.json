{
  "expo": {
    "name": "Gully Cricket Scorer",
    "slug": "gully-cricket-scorer",
    "version": "1.0.6",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "gullycricket",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#00695C"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gullycricket.scorer",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Used to show nearby cricket teams first."
      }
    },
    "android": {
      "package": "com.gullycricket.scorer",
      "versionCode": 7,
      "adaptiveIcon": {
        "backgroundColor": "#00695C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro",
      "output": "single"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Used to show nearby cricket teams first."
        }
      ],
      [
        "expo-system-ui",
        {
          "backgroundColor": "#00695C"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "cameraPermission": false
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "210e2d8e-9814-4ba7-a087-ee74378ade7d"
      }
    },
    "owner": "mrkalakota"
  }
}
