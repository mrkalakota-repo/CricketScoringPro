# Local-only scripts — not needed for EAS Build
scripts/

# Native directories — EAS regenerates these via expo prebuild from app.json.
# Excluding them ensures versionCode/versionName always come from app.json.
ios/
android/

# Build artifacts and caches
dist/

# Local dev caches
.expo/
.git/

# IDE and OS files
.idea/
.DS_Store
*.DS_Store

# Docs
docs/
